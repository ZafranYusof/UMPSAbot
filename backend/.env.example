# Server
PORT=5005
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/umpsa-chatbot?retryWrites=true&w=majority

# Groq API (Primary LLM provider)
GROQ_API_KEY=gsk_your_groq_api_key_here

# OpenRouter API (Secondary fallback - OpenAI-compatible)
# Get key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Cerebras API (Tertiary fallback - OpenAI-compatible)
# Get key at https://cloud.cerebras.ai/
CEREBRAS_API_KEY=csk-your_cerebras_api_key_here
CEREBRAS_MODEL=llama-3.3-70b

# LLM Settings
LLM_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=llama-3.3-70b-versatile

# RAG Settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=5
CONFIDENCE_THRESHOLD=0.3

# Cache Settings
CACHE_SIMILARITY_THRESHOLD=0.92

# Twilio WhatsApp Integration
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
